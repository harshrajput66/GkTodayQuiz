# Backend Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL Connection String
# Local: postgresql://username:password@localhost:5432/quiz_db
# Neon:  postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/quiz_db?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/quiz_db"

# JWT Secret (change this to a long random string in production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# Quiz Settings
QUIZ_QUESTIONS_COUNT=30
QUIZ_TIMER_MINUTES=30
QUIZ_PASS_PERCENTAGE=60

# CORS
FRONTEND_URL=http://localhost:5173
